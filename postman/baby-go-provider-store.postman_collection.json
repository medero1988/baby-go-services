{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Baby Go — Provider Store",
    "description": "API store proveedor (base: /api/v1/store).\n\nVariables de colección:\n- `baseUrl`: http://localhost:3000/api\n- `storeId`: id MongoDB de la store (tras crear perfil)\n- `token`: JWT (opcional si usás ENABLE_DEV_AUTH_BYPASS en local)\n\nAuth: Bearer {{token}}. En dev sin token, el backend puede usar usuario dev.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "storeId",
      "value": ""
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "paymentId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Store",
      "item": [
        {
          "name": "1. Listar stores",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/store",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "store"]
            },
            "description": "GET todas las stores."
          },
          "response": []
        },
        {
          "name": "1b. Obtener perfil por id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/store/{{storeId}}/profile",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "store", "{{storeId}}", "profile"]
            },
            "description": "GET perfil de una store por id (debe pertenecer al usuario autenticado)."
          },
          "response": []
        },
        {
          "name": "2. Crear perfil (store)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Baby Confy\",\n  \"country\": \"NL\",\n  \"address\": {\n    \"addressLine1\": \"Seevank 144, 1161 AR Zwanenburg, Netherlands\",\n    \"addressLine2\": \"alguna indicacion extra\",\n    \"placeId\": \"ChIJxxxxxxxxxxxxxxxxxxxx\"\n  },\n  \"cellPhone\": \"+315615628854\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/store/profile",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "store", "profile"]
            },
            "description": "Respuesta incluye `id` → copiar a variable `storeId`."
          },
          "response": []
        },
        {
          "name": "2b. Actualizar perfil (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Baby Confy Updated\",\n  \"address\": {\n    \"addressLine2\": \"nueva indicacion extra\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/store/{{storeId}}/profile",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "store", "{{storeId}}", "profile"]
            },
            "description": "Actualización parcial. Todos los campos son opcionales: name, country, address, cellPhone."
          },
          "response": []
        },
        {
          "name": "3. Reenviar código SMS",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/store/{{storeId}}/cell-verification/resend",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "store", "{{storeId}}", "cell-verification", "resend"]
            }
          },
          "response": []
        },
        {
          "name": "4. Validar código celular",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/store/{{storeId}}/cell-verification",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "store", "{{storeId}}", "cell-verification"]
            }
          },
          "response": []
        },
        {
          "name": "5. Subir avatar",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "avatar",
                  "type": "file",
                  "src": [],
                  "description": "Seleccioná una imagen (jpg/png/webp/gif, máx 5MB)"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/v1/store/{{storeId}}/avatar",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "store", "{{storeId}}", "avatar"]
            }
          },
          "response": []
        },
        {
          "name": "6a. Delivery — horario por días",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"available\": true,\n  \"timeRanges\": [\n    \"7:30-9:30\",\n    \"12:30-14:00\",\n    \"17:30-19:00\",\n    \"10:00-15:00\"\n  ],\n  \"days\": {\n    \"mon\": [0, 1, 2],\n    \"tue\": [0, 1],\n    \"sat\": [3]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/store/{{storeId}}/delivery",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "store", "{{storeId}}", "delivery"]
            }
          },
          "response": []
        },
        {
          "name": "6b. Delivery — 24/7",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"available\": true,\n  \"available24h\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/store/{{storeId}}/delivery",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "store", "{{storeId}}", "delivery"]
            }
          },
          "response": []
        },
        {
          "name": "6c. Delivery pricing",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"basePrice\": 100,\n  \"priceKm\": 30,\n  \"maxDeliveryDistance\": 30\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/store/{{storeId}}/delivery-pricing",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "store", "{{storeId}}", "delivery-pricing"]
            },
            "description": "Precios en centavos. Requiere haber configurado delivery (6a/6b) antes."
          },
          "response": []
        },
        {
          "name": "7a. Customer pickup — horario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"available\": true,\n  \"timeRanges\": [\n    \"7:30-9:30\",\n    \"12:30-14:00\",\n    \"17:30-19:00\",\n    \"10:00-15:00\"\n  ],\n  \"days\": {\n    \"mon\": [0, 1],\n    \"thu\": [2],\n    \"sat\": [3]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/store/{{storeId}}/customer-pickup",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "store", "{{storeId}}", "customer-pickup"]
            },
            "description": "Máx. 2 intervalos por día. También soporta available24h: true."
          },
          "response": []
        },
        {
          "name": "7a. Customer pickup — 24/7",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"available\": true,\n  \"available24h\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/store/{{storeId}}/customer-pickup",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "store", "{{storeId}}", "customer-pickup"]
            },
            "description": "Sólo soporta available24h: true."
          },
          "response": []
        },
        {
          "name": "7a. Datos bancarios (payout)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountType\": \"IBAN\",\n  \"firstName\": \"Jhon\",\n  \"lastName\": \"Doe\",\n  \"country\": \"NL\",\n  \"currency\": \"eur\",\n  \"iban\": \"NL91ABNA0417164300\",\n  \"bankName\": \"ABN AMRO\",\n  \"swiftCode\": \"ABNANL2A\",\n  \"address\": \"Seevank 144, Zwanenburg\",\n  \"entityType\": \"individual\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/store/{{storeId}}/bank-account",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "store", "{{storeId}}", "bank-account"]
            },
            "description": "Guarda los datos bancarios (payout) de la store y los tokeniza en Stripe.\n\n- `accountType`: `IBAN` (usar campo `iban`) o `NUMBER` (usar campo `accountNumber` + `routingNumber`).\n- No se persiste el IBAN/nro completo: se guarda `last4` + el token de Stripe.\n- Respuesta incluye `bankAccount` y `bankAccountTk` (id de Stripe).\n- Setea `meta.lastSteep = 'bank-account'`.\n\nStripe (test) valida el checksum del IBAN. Usá un IBAN válido de test.\n\nEjemplo US (accountType NUMBER):\n{\n  \"accountType\": \"NUMBER\",\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\",\n  \"country\": \"US\",\n  \"currency\": \"usd\",\n  \"accountNumber\": \"000123456789\",\n  \"routingNumber\": \"110000000\",\n  \"bankName\": \"STRIPE TEST BANK\"\n}"
          },
          "response": []
        },
        {
          "name": "7ab. Confirmación final (Create store)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"acceptedTerms\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/store/{{storeId}}/confirmation",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "store", "{{storeId}}", "confirmation"]
            },
            "description": "Paso final del funnel (botón Create store / Information review).\n\nRequiere:\n- `acceptedTerms: true`\n- celular validado\n- bank-account configurado\n\nResultado:\n- `meta.state` = `pending-review` (revisión Baby Go ~24h)\n- `meta.lastSteep` = `confirmation`\n- `meta.confirmedAt` = ISO timestamp\n\nLa store queda lista para agregar productos; visibles a clientes cuando pase a `active`."
          },
          "response": []
        },
        {
          "name": "7b. Stripe Connect — account link",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"returnUrl\": \"http://localhost:3000/api/stripe-connect/return\",\n  \"refreshUrl\": \"http://localhost:3000/api/stripe-connect/refresh\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/store/{{storeId}}/stripe-connect/account-link",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "store", "{{storeId}}", "stripe-connect", "account-link"]
            },
            "description": "Crea cuenta Connect Express (si no existe) y devuelve URL de onboarding Stripe.\n\n1. Ejecutá este request → copiá `url` de la respuesta.\n2. Abrí `url` en el browser y completá el onboarding (datos de prueba Stripe).\n3. Ejecutá **7c. sync status** → verificá `stripeConnect.onboardingComplete: true`.\n4. Recién ahí podés crear pagos (colección baby-go-payments).\n\nStripe exige URLs http(s); no acepta deep links (`babygo://`)."
          },
          "response": []
        },
        {
          "name": "7c. Stripe Connect — sync status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/store/{{storeId}}/stripe-connect/status",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "store", "{{storeId}}", "stripe-connect", "status"]
            },
            "description": "Sincroniza estado Connect desde Stripe y devuelve perfil store con `stripeConnect`."
          },
          "response": []
        },
        {
          "name": "7d. Movimientos de pagos (todas las stores)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/store/movements?status=transferred",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "store", "movements"],
              "query": [
                {
                  "key": "status",
                  "value": "transferred",
                  "description": "Opcional. Filtra por estado del pago (succeeded, transferred, etc.).",
                  "disabled": true
                },
                {
                  "key": "storeId",
                  "value": "{{storeId}}",
                  "description": "Opcional. Filtra por una store puntual.",
                  "disabled": true
                }
              ]
            },
            "description": "Movimientos de pagos de todas las stores del proveedor autenticado.\n\nDevuelve `summary` (cobrado, ganancias transferidas, pendientes y comisión de la plataforma) + `movements` (detalle por pago).\n\nFiltros opcionales por query: `status`, `storeId`."
          },
          "response": []
        },
        {
          "name": "7e. Movimientos de pagos (store puntual)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/store/{{storeId}}/movements",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "store", "{{storeId}}", "movements"]
            },
            "description": "Movimientos de pagos de una store puntual del proveedor. Acepta `?status=` opcional."
          },
          "response": []
        },
        {
          "name": "8. Eliminar store",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/store/{{storeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "store", "{{storeId}}"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
